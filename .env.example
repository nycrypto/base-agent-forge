# Base Agent Forge example environment file
# Copy this file as .env.local when running locally.
# Never commit .env.local to GitHub.

NEXT_PUBLIC_APP_NAME="Base Agent Forge"

# Network
BASE_NETWORK="base-sepolia"

# Payment mode
# disabled = no real payment
# demo = mock x402 flow
# live = real payment integration, not enabled by default
PAYMENT_MODE="disabled"

# AI provider
# Leave empty until you want to connect a real AI model.
OPENAI_API_KEY="your_openai_api_key_here"

# Coinbase Developer Platform
# Leave these empty until real AgentKit/CDP integration is added.
CDP_API_KEY_ID="your_cdp_api_key_id_here"
CDP_API_KEY_SECRET="your_cdp_api_key_secret_here"

# Wallet safety
# Never paste a real private key into public files.
AGENT_WALLET_PRIVATE_KEY="never_commit_real_private_keys"